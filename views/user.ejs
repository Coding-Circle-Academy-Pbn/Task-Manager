<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>User Profile</title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class=" flex items-center justify-center min-h-screen">

<%- include('partials/sidebar') %>
  <div class="bg-gray-800 w-full max-w-sm rounded-2xl shadow-2xl p-8 border border-gray-700">

    <!-- Profile Icon -->
    <div class="flex justify-center mb-6">
      <div class="w-24 h-24 rounded-full bg-blue-600 flex items-center justify-center text-white text-4xl font-bold shadow-lg">
        U
      </div>
    </div>

    <!-- Heading -->
    <h2 class="text-center text-3xl font-bold text-white mb-8">
      User Profile
    </h2>

    <!-- Username -->
    <div class="mb-5">
      <label class="block text-sm font-medium text-gray-300 mb-2">
        Username
      </label>

      <input
        type="text"
        placeholder="John Doe"
        class="w-full p-3 rounded-lg bg-gray-700 border border-gray-600 text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:outline-none"
        value="<%= users.name %>"
      />
    </div>

    <!-- Email -->
    <div class="mb-5">
      <label class="block text-sm font-medium text-gray-300 mb-2">
        Email
      </label>

      <input
        type="email"
        value="<%= users.email %>"
        placeholder="john@example.com"
        class="w-full p-3 rounded-lg bg-gray-700 border border-gray-600 text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:outline-none"
      />
    </div>

    <!-- Password -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-gray-300 mb-2">
        Password
      </label>

      <input

        type="password"
        placeholder="••••••••"
        value="••••••••"
        class="w-full p-3 rounded-lg bg-gray-700 border border-gray-600 text-white placeholder-gray-400 focus:ring-2 focus:ring-blue-500 focus:outline-none"
      />
    </div>

    <!-- Button -->
    <button
      class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition duration-300"
    >
      Update Profile
    </button>

  </div>

</body>
</html>